<% layout("/layouts/boilerplate") %>
<body>
    <h3>Listings  </h3>
    <!-- <form action="/listings/new" method="GET">  
        <button type="submit">ADD</button>
    </form> -->

    <!-- card -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
<% for(let i = 0; i < display.length; i++) { %>
   <a href="/listings/<%= display[i]._id %>" style="text-decoration: none; color: black;"> 
 <div class="card col" >
  <img src="<%= display[i].image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;" >
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-title"><b><%= display[i].title %></b></p>
    <p class="card-price">&#8377;<%= display[i].price.toLocaleString("en-IN")%> / night</p>
   
  </div>
 </div>
  </a> 
 <% } %>
</div>

</body>
