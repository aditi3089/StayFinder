<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>stayfinder listing</title>
</head>
<body>
    <h3>Listings  </h3>
    <form action="/listings/new" method="GET">  
        <button type="submit">ADD</button>
    </form>

    <ul>
       <% for(let i = 0; i < display.length; i++) { %>
           <li><a href="/listings/<%= display[i]._id %>"><%= display[i].title %></a></li>
        <% } %>
    <ul>
</body>
</html>